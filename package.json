{
  "name": "@taizhixuan/autosort",
  "version": "1.0.2",
  "description": "Smart Downloads Organizer - automatically organize the files in any folder by type, name, size, or age",
  "main": "src/index.js",
  "bin": {
    "autosort": "src/cli.js"
  },
  "files": [
    "src/",
    "autosort.config.example.json",
    "README.md",
    "SETUP.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js start",
    "organize": "node src/cli.js organize",
    "dev": "node --watch src/cli.js start",
    "cli": "node src/cli.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "file-organizer",
    "automation",
    "file-watcher",
    "downloads-manager",
    "productivity-tool",
    "nodejs"
  ],
  "author": "taizhixuan",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taizhixuan/AutoSort.git"
  },
  "homepage": "https://github.com/taizhixuan/AutoSort#readme",
  "bugs": {
    "url": "https://github.com/taizhixuan/AutoSort/issues"
  }
}
